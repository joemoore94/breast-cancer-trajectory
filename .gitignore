# Data (downloaded/derived - too large for git)
data/raw/*
data/processed/*
data/reference/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/reference/.gitkeep

# Results that can be regenerated
results/figures/*
results/tables/*
!results/figures/.gitkeep
!results/tables/.gitkeep
# ...except figure PNGs, which the README links to and should render on GitHub
!results/figures/*.png

# Workflow state/logs
.snakemake/
logs/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/

# Environments
.venv/
env/

# OS
.DS_Store
